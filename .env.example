# Google Cloud Project ID
PROJECT_ID=test-project

# Google Cloud Region
REGION=us-central1

# Log Level (DEBUG, INFO, WARN, ERROR)
LOG_LEVEL=DEBUG

# Gemini API Key (Required)
GEMINI_API_KEY=your_gemini_api_key_here

# Pub/Sub Topic and Subscription for Scan Requests
PUBSUB_TOPIC_SCAN_REQUESTS=scan-requests
PUBSUB_SUB_SCAN_REQUESTS=scan-requests-sub

# Server Port
PORT=8080

# Next.js API URL (frontend needs to know backend URL)
NEXT_PUBLIC_API_URL=http://localhost:8080
